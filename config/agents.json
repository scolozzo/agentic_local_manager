  "providers": {
    "zai": {
      "label": "Z.AI (GLM)",
      "env_key": "ZAI_API_KEY",
      "models": [
        "glm-4.7-flash",
        "glm-4.7"
      ]
    },
    "minimax": {
      "label": "MiniMax",
      "env_key": "MINIMAX_API_KEY",
      "models": [
        "minimax-m2.5-standard"
      ]
    },
    "openai": {
      "label": "OpenAI (Codex)",
      "env_key": "OPENAI_API_KEY",
      "models": [
        "gpt-4.1",
        "o4-mini",
        "codex-5.3"
      ]
    }
