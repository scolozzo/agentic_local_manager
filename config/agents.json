{
  "version": 2,
  "default_preset": "default_software_team",
  "roles": {
    "pm": {
      "label": "Project Manager",
      "prompt": "config/prompts/base/pm.md"
    },
    "developer": {
      "label": "Developer",
      "prompt": "config/prompts/base/developer.md"
    },
    "qa": {
      "label": "Quality Assurance",
      "prompt": "config/prompts/base/qa.md"
    },
    "orchestrator": {
      "label": "Orchestrator",
      "prompt": "config/prompts/base/orchestrator.md"
    }
  },
  "stacks": {
    "backend": {
      "label": "Backend",
      "stack_key": "BACK",
      "prompts": {
        "developer": "config/prompts/stacks/backend.md",
        "qa": "config/prompts/stacks/qa_backend.md"
      }
    },
    "front_web": {
      "label": "Frontend Web",
      "stack_key": "BO",
      "prompts": {
        "developer": "config/prompts/stacks/front_web.md",
        "qa": "config/prompts/stacks/qa_front_web.md"
      }
    },
    "front_mobile": {
      "label": "Frontend Mobile",
      "stack_key": "MOB",
      "prompts": {
        "developer": "config/prompts/stacks/front_mobile.md",
        "qa": "config/prompts/stacks/qa_front_mobile.md"
      }
    },
    "database": {
      "label": "Database",
      "stack_key": "BACK",
      "prompts": {
        "developer": "config/prompts/stacks/db.md",
        "qa": "config/prompts/stacks/qa_backend.md"
      }
    }
  },
  "agents": [
    {
      "id": "pm",
      "name": "PM Agent",
      "type": "pm",
      "role": "pm",
      "script": "pm_integration.py",
      "stack": "backend",
      "stack_key": "BACK",
      "specialization": "project_manager",
      "base_prompt": "config/prompts/base/pm.md",
      "stack_prompt": null,
      "specialization_prompt": null,
      "provider": "zai",
      "model": "glm-4.7-flash",
      "log_file": "pm.log",
      "enabled": true,
      "removable": false
    },
    {
      "id": "orchestrator",
      "name": "Orchestrator",
      "type": "orchestrator",
      "role": "orchestrator",
      "script": "orchestrator_integration.py",
      "stack": "backend",
      "stack_key": "BACK",
      "specialization": "orchestrator",
      "base_prompt": "config/prompts/base/orchestrator.md",
      "stack_prompt": null,
      "specialization_prompt": null,
      "provider": "zai",
      "model": "glm-4.7-flash",
      "log_file": "orchestrator.log",
      "enabled": true,
      "removable": false
    },
    {
      "id": "dev1",
      "name": "Dev 1",
      "login": "botidev1",
      "type": "dev",
      "role": "developer",
      "script": "developer_integration.py",
      "stack": "backend",
      "stack_key": "BACK",
      "specialization": "backend",
      "base_prompt": "config/prompts/base/developer.md",
      "stack_prompt": "config/prompts/stacks/backend.md",
      "specialization_prompt": "config/prompts/specializations/dev_back.md",
      "provider": "zai",
      "model": "glm-4.7-flash",
      "log_file": "dev1.log",
      "enabled": true,
      "removable": true
    },
    {
      "id": "dev2",
      "name": "Dev 2",
      "login": "botidev2",
      "type": "dev",
      "role": "developer",
      "script": "developer_integration.py",
      "stack": "backend",
      "stack_key": "BACK",
      "specialization": "backend",
      "base_prompt": "config/prompts/base/developer.md",
      "stack_prompt": "config/prompts/stacks/backend.md",
      "specialization_prompt": "config/prompts/specializations/dev_back.md",
      "provider": "zai",
      "model": "glm-4.7-flash",
      "log_file": "dev2.log",
      "enabled": true,
      "removable": true
    },
    {
      "id": "dev3",
      "name": "Dev 3",
      "login": "botidev3",
      "type": "dev",
      "role": "developer",
      "script": "developer_integration.py",
      "stack": "backend",
      "stack_key": "BACK",
      "specialization": "backend",
      "base_prompt": "config/prompts/base/developer.md",
      "stack_prompt": "config/prompts/stacks/backend.md",
      "specialization_prompt": "config/prompts/specializations/dev_back.md",
      "provider": "zai",
      "model": "glm-4.7-flash",
      "log_file": "dev3.log",
      "enabled": true,
      "removable": true
    },
    {
      "id": "qa",
      "name": "QA Agent",
      "type": "qa",
      "role": "qa",
      "script": "qa_integration.py",
      "stack": "backend",
      "stack_key": "BACK",
      "specialization": "qa_backend",
      "base_prompt": "config/prompts/base/qa.md",
      "stack_prompt": "config/prompts/stacks/qa_backend.md",
