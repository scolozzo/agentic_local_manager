{
  "default_template": "software_delivery_default",
  "templates": {
    "software_delivery_default": {
      "label": "Software Delivery Default",
      "description": "Template fundador que preserva el workflow actual del tablero local.",
      "workflow": {
        "states": [
          "Todo",
          "InProgress",
          "QA",
          "Fixing",
          "ReadyToMerge",
          "Merged",
          "Blocked"
        ],
        "transitions": [
          "Todo -> InProgress",
          "InProgress -> QA",
          "QA -> Fixing",
          "QA -> ReadyToMerge",
          "Fixing -> QA",
          "ReadyToMerge -> Merged",
          "Blocked -> Todo"
        ]
      },
      "allowed_stacks": [
        "BACK",
        "BO",
        "MOB"
      ],
      "required_roles": [
        "pm",
        "orchestrator",
        "developer",
        "qa"
      ],
      "suggested_preset": "default_software_team",
      "expected_artifacts": [
        "feature_branch",
        "merge_request",
        "qa_report"
      ]
    },
